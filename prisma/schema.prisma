generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SchoolRole {
  school_admin
  teacher
  student
  parent
}

enum Locale {
  en
  ml
}

enum RightsBasis {
  original
  cc_by_4_0
  public_domain
  written_permission
}

enum StudioStatus {
  planning
  ready_for_student
  awaiting_teacher_review
  ready_for_family
  complete
  archived
}

enum ContentOrigin {
  teacher_authored
  gpt_5_6
}

enum AiStatus {
  not_requested
  ready
  unavailable
  rejected
}

enum CurriculumStatus {
  active
  archived
}

enum ScaffoldLevel {
  guided
  light
  independent
}

enum FamilyResponse {
  not_sent
  tried
  need_another_idea
  contact_teacher
}

enum AiRunStatus {
  succeeded
  rejected
  provider_error
}

model School {
  id              String           @id @default(cuid())
  slug            String           @unique @db.VarChar(80)
  name            String           @db.VarChar(160)
  state           String           @default("Kerala") @db.VarChar(80)
  timezone        String           @default("Asia/Kolkata") @db.VarChar(64)
  memberships     Membership[]
  curriculumPacks CurriculumPack[]
  studios         LearningStudio[]
  aiRuns          AiRun[]
  auditEvents     AuditEvent[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique @db.VarChar(320)
  displayName  String       @db.VarChar(120)
  passwordHash String
  locale       Locale       @default(en)
  isActive     Boolean      @default(true)
  memberships  Membership[]
  sessions     Session[]
  auditEvents  AuditEvent[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([isActive])
}

model Membership {
  id                    String            @id @default(cuid())
  schoolId              String
  userId                String
  role                  SchoolRole
  isActive              Boolean           @default(true)
  school                School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions              Session[]
  teacherAssignments    TeacherStudent[]  @relation("TeacherAssignments")
  studentTeachers       TeacherStudent[]  @relation("StudentTeachers")
  guardianAssignments   GuardianStudent[] @relation("GuardianAssignments")
  studentGuardians      GuardianStudent[] @relation("StudentGuardians")
  authoredPacks         CurriculumPack[]  @relation("PackAuthor")
  teachingStudios       LearningStudio[]  @relation("StudioTeacher")
  learningStudios       LearningStudio[]  @relation("StudioStudent")
  guardianStudios       LearningStudio[]  @relation("StudioGuardian")
  completedReviews      TeacherReview[]   @relation("ReviewTeacher")
  studentHelps          StudentHelp[]      @relation("StudentHelpStudent")
  aiRuns                AiRun[]           @relation("AiRunActor")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([schoolId, userId, role])
  @@index([schoolId, role, isActive])
  @@index([userId, isActive])
}

model TeacherStudent {
  id                    String     @id @default(cuid())
  teacherMembershipId   String
  studentMembershipId   String
  teacherMembership     Membership @relation("TeacherAssignments", fields: [teacherMembershipId], references: [id], onDelete: Cascade)
  studentMembership     Membership @relation("StudentTeachers", fields: [studentMembershipId], references: [id], onDelete: Cascade)
  createdAt             DateTime   @default(now())

  @@unique([teacherMembershipId, studentMembershipId])
  @@index([studentMembershipId])
}

model GuardianStudent {
  id                    String     @id @default(cuid())
  guardianMembershipId  String
  studentMembershipId   String
  guardianMembership    Membership @relation("GuardianAssignments", fields: [guardianMembershipId], references: [id], onDelete: Cascade)
  studentMembership     Membership @relation("StudentGuardians", fields: [studentMembershipId], references: [id], onDelete: Cascade)
  createdAt             DateTime   @default(now())

  @@unique([guardianMembershipId, studentMembershipId])
  @@index([studentMembershipId])
}

model Session {
  id            String     @id @default(cuid())
  tokenHash     String     @unique @db.VarChar(64)
  userId        String
  membershipId  String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership    Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  lastSeenAt    DateTime   @default(now())
  createdAt     DateTime   @default(now())

  @@index([userId, expiresAt])
  @@index([membershipId, expiresAt])
  @@index([expiresAt])
}

model LoginThrottle {
  keyHash      String   @id @db.VarChar(64)
  failureCount Int      @default(0)
  resetAt      DateTime
  updatedAt    DateTime @updatedAt

  @@index([resetAt])
}

model CurriculumPack {
  id                    String              @id @default(cuid())
  schoolId              String
  createdByMembershipId String
  title                 String              @db.VarChar(180)
  subject               String              @db.VarChar(80)
  gradeLabel            String              @db.VarChar(40)
  version               String              @db.VarChar(40)
  rightsBasis           RightsBasis
  sourceUrl             String?             @db.VarChar(500)
  locale                Locale               @default(en)
  checksum              String               @db.VarChar(64)
  status                CurriculumStatus     @default(active)
  school                School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdByMembership   Membership           @relation("PackAuthor", fields: [createdByMembershipId], references: [id], onDelete: Restrict)
  sections              CurriculumSection[]
  studios               LearningStudio[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([schoolId, status, subject, gradeLabel])
  @@index([createdByMembershipId, createdAt])
}

model CurriculumSection {
  id          String         @id @default(cuid())
  packId      String
  referenceId String         @db.VarChar(12)
  heading     String         @db.VarChar(160)
  content     String         @db.Text
  position    Int
  checksum    String         @db.VarChar(64)
  pack        CurriculumPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@unique([packId, referenceId])
  @@unique([packId, position])
  @@index([packId, position])
}

model LearningStudio {
  id                    String            @id @default(cuid())
  schoolId              String
  teacherMembershipId   String
  studentMembershipId   String
  guardianMembershipId  String?
  curriculumPackId      String
  title                 String            @db.VarChar(160)
  subject               String            @db.VarChar(80)
  gradeLabel            String            @db.VarChar(40)
  goal                  String            @db.VarChar(320)
  drivingQuestion       String            @db.VarChar(300)
  status                StudioStatus      @default(planning)
  familyLocale          Locale            @default(ml)
  planOrigin            ContentOrigin     @default(teacher_authored)
  aiStatus              AiStatus          @default(not_requested)
  studentHelpStatus     AiStatus          @default(not_requested)
  plan                  Json
  planPromptVersion     String            @default("teacher-starter-v1") @db.VarChar(60)
  aiModel               String?           @db.VarChar(120)
  scaffoldLevel         ScaffoldLevel     @default(guided)
  version               Int               @default(1)
  planReviewedAt        DateTime?
  publishedAt           DateTime?
  evidenceSubmittedAt   DateTime?
  reviewedAt            DateTime?
  familyRespondedAt     DateTime?
  school                School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherMembership     Membership        @relation("StudioTeacher", fields: [teacherMembershipId], references: [id], onDelete: Restrict)
  studentMembership     Membership        @relation("StudioStudent", fields: [studentMembershipId], references: [id], onDelete: Restrict)
  guardianMembership    Membership?       @relation("StudioGuardian", fields: [guardianMembershipId], references: [id], onDelete: SetNull)
  curriculumPack        CurriculumPack    @relation(fields: [curriculumPackId], references: [id], onDelete: Restrict)
  submission            LearnerSubmission?
  teacherReview         TeacherReview?
  familyHandoff         FamilyHandoff?
  studentHelp           StudentHelp?
  aiRuns                AiRun[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([schoolId, status, updatedAt])
  @@index([teacherMembershipId, status, updatedAt])
  @@index([studentMembershipId, status, updatedAt])
  @@index([guardianMembershipId, status, updatedAt])
  @@index([curriculumPackId])
}

model LearnerSubmission {
  id                String         @id @default(cuid())
  studioId          String         @unique
  interestHookIndex Int
  makerChoiceId     String         @db.VarChar(48)
  prediction        String         @db.Text
  firstDraft        String         @db.Text
  selfCritique      String         @db.Text
  revision          String         @db.Text
  explanation       String         @db.Text
  reflection        String         @db.Text
  supportOpened     Boolean        @default(false)
  studio            LearningStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  submittedAt       DateTime       @default(now())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model TeacherReview {
  id                    String         @id @default(cuid())
  studioId              String         @unique
  teacherMembershipId   String
  noticedStrength       String         @db.VarChar(500)
  studentFeedback       String         @db.VarChar(700)
  nextQuestion          String         @db.VarChar(300)
  nextScaffoldLevel     ScaffoldLevel
  familyActivity        String         @db.VarChar(700)
  studio                LearningStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  teacherMembership     Membership     @relation("ReviewTeacher", fields: [teacherMembershipId], references: [id], onDelete: Restrict)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([teacherMembershipId, createdAt])
}

model FamilyHandoff {
  id          String         @id @default(cuid())
  studioId    String         @unique
  activity    String         @db.VarChar(700)
  response    FamilyResponse @default(not_sent)
  parentNote  String?        @db.VarChar(400)
  respondedAt DateTime?
  studio      LearningStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model StudentHelp {
  id                    String         @id @default(cuid())
  studioId              String         @unique
  studentMembershipId   String
  response              Json
  sourceSectionIds      Json
  model                 String         @db.VarChar(120)
  promptVersion         String         @db.VarChar(60)
  studio                LearningStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  studentMembership     Membership     @relation("StudentHelpStudent", fields: [studentMembershipId], references: [id], onDelete: Restrict)
  createdAt             DateTime       @default(now())

  @@index([studentMembershipId, createdAt])
}

model AiRun {
  id                    String         @id @default(cuid())
  schoolId              String
  studioId              String
  actorMembershipId     String
  purpose               String         @db.VarChar(60)
  provider              String         @db.VarChar(40)
  model                 String         @db.VarChar(120)
  status                AiRunStatus
  promptVersion         String         @db.VarChar(60)
  inputTokens           Int?
  outputTokens          Int?
  costMicros            Int?
  latencyMs             Int
  errorCode             String?        @db.VarChar(60)
  citationIds           Json
  school                School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studio                LearningStudio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  actorMembership       Membership     @relation("AiRunActor", fields: [actorMembershipId], references: [id], onDelete: Restrict)
  createdAt             DateTime       @default(now())

  @@index([schoolId, createdAt])
  @@index([studioId, createdAt])
  @@index([actorMembershipId, createdAt])
}

model AuditEvent {
  id          String   @id @default(cuid())
  schoolId    String
  actorUserId String?
  action      String   @db.VarChar(80)
  entityType  String   @db.VarChar(80)
  entityId    String   @db.VarChar(120)
  metadata    Json?
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

# Local PostgreSQL started by compose.yaml
KANNI_DB_PASSWORD=kanni_local_only_change_me
DATABASE_URL=postgresql://kanni:kanni_local_only_change_me@127.0.0.1:5436/kanni?schema=public
TEST_DATABASE_URL=postgresql://kanni:kanni_local_only_change_me@127.0.0.1:5436/kanni_test?schema=public
DATABASE_POOL_SIZE=10

# Local authentication. Replace this before using shared or real data.
AUTH_SECRET=kanni-local-auth-secret-change-before-shared-use-2026
AUTH_TRUST_PROXY=false
KANNI_SEED_LOCAL_ACCOUNTS=true
REVIEW_ACCESS_VISIBLE=true
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional AI. Kanni is complete with this disabled.
GROWTH_AI_PROVIDER=disabled
GROWTH_AI_MODEL=openai/gpt-5.6-sol
OPENROUTER_API_KEY=
GROWTH_AI_ENABLED=false
GROWTH_AI_RATE_LIMIT_CONFIRMED=false
GROWTH_AI_SPEND_LIMIT_CONFIRMED=false

POSTGRES_USER=kanni
# Use a URL-safe random value, for example: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=kanni
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_TRUST_PROXY=false
APP_PORT=3001
DATABASE_POOL_SIZE=10
NEXT_PUBLIC_APP_URL=https://kanni.example.org
REVIEW_ACCESS_VISIBLE=false

# Required only when running the optional review-account seed command.
KANNI_SEED_LOCAL_ACCOUNTS=false
SEED_ADMIN_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_STUDENT_PASSWORD=
SEED_PARENT_PASSWORD=

# Optional AI provider. Keep disabled until provider, budget, and host rate limits are set.
GROWTH_AI_PROVIDER=disabled
GROWTH_AI_MODEL=openai/gpt-5.6-luna
OPENROUTER_API_KEY=
GROWTH_AI_ENABLED=false
GROWTH_AI_RATE_LIMIT_CONFIRMED=false
GROWTH_AI_SPEND_LIMIT_CONFIRMED=false

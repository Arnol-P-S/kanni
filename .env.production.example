POSTGRES_USER=kanni
# Use a URL-safe random value, for example: openssl rand -hex 32
POSTGRES_PASSWORD=replace_with_a_long_random_database_password
POSTGRES_DB=kanni
AUTH_SECRET=replace_with_at_least_32_random_characters
AUTH_TRUST_PROXY=false
APP_HOST=127.0.0.1
APP_PORT=3001
DATABASE_POOL_SIZE=10
NEXT_PUBLIC_APP_URL=https://your-kanni-host.example

# Keep AI disabled until provider, budget, and ingress rate controls are ready.
GROWTH_AI_PROVIDER=disabled
GROWTH_AI_MODEL=openai/gpt-5.6-luna
OPENROUTER_API_KEY=
GROWTH_AI_ENABLED=false
GROWTH_AI_RATE_LIMIT_CONFIRMED=false
GROWTH_AI_SPEND_LIMIT_CONFIRMED=false
# Enable both only after reviewing student-data processing and supervision controls.
GROWTH_AI_STUDENT_HELP_ENABLED=false
GROWTH_AI_STUDENT_DATA_REVIEW_CONFIRMED=false
